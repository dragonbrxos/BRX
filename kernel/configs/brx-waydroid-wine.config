# =============================================================================
# BRX OS — Kernel Configs: Waydroid & Wine/Proton
# =============================================================================
# Configurações necessárias para suporte total a:
#   - Waydroid (Android apps)
#   - Wine/Proton (Windows apps/games)
#   - Fsync/Esync (Latência mínima em jogos)
# =============================================================================

# 1. Waydroid (Android Container)
# -----------------------------------------------------------------------------
CONFIG_ANDROID=y
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y
CONFIG_ANDROID_BINDER_DEVICES="binder,hwbinder,vndbinder"
CONFIG_ANDROID_BINDER_IPC_SELFTEST=y
CONFIG_ASHMEM=y
CONFIG_PSI=y
CONFIG_PSI_DEFAULT_DISABLED=n

# 2. Wine/Proton (Fsync & Esync)
# -----------------------------------------------------------------------------
CONFIG_FUTEX=y
CONFIG_FUTEX_PI=y
# Fsync (Fast Futex) — Mergeado no 5.16+, otimizado no BRX 6.12
CONFIG_FUTEX_INTERRUPTIBLE=y

# 3. Gráficos (Vulkan & Wayland)
# -----------------------------------------------------------------------------
CONFIG_DRM_AMDGPU=y
CONFIG_DRM_AMDGPU_SI=y
CONFIG_DRM_AMDGPU_CIK=y
CONFIG_DRM_AMDGPU_USERPTR=y
CONFIG_DRM_XE=y
CONFIG_DRM_I915=y
CONFIG_DRM_NOUVEAU=y
CONFIG_DRM_NOUVEAU_GSP_TARGA=y

# 4. Outros requisitos de compatibilidade
# -----------------------------------------------------------------------------
CONFIG_USER_NS=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_CHECKPOINT_RESTORE=y
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_BLK_CGROUP=y
