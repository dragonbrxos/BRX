# =============================================================================
# KanelOS — Configuração de Kernel: Perfil Desktop
# Base: Linux 6.12 LTS
# Otimizado para: Gaming, Workstation, Uso Geral
# =============================================================================
# Gerado com base em:
# - CachyOS kernel config (BORE+EEVDF)
# - Arch Linux kernel config
# - Benchmarks Phoronix Test Suite
# - Documentação oficial kernel.org
# =============================================================================

# --- Identificação ---
CONFIG_LOCALVERSION="-kanelos-desktop"
CONFIG_LOCALVERSION_AUTO=y

# --- Arquitetura e CPU ---
CONFIG_X86_64=y
CONFIG_64BIT=y
CONFIG_X86_INTEL_USERCOPY=y
CONFIG_X86_USE_PPRO_CHECKSUM=y
CONFIG_GENERIC_CPU=y
# Descomente para CPUs específicas:
# CONFIG_MNATIVE_INTEL=y   # Intel 12th Gen+
# CONFIG_MNATIVE_AMD=y     # AMD Ryzen 5000+
CONFIG_NR_CPUS=512
CONFIG_SCHED_SMT=y
CONFIG_SCHED_MC=y
CONFIG_SCHED_MC_PRIO=y

# --- Scheduler: EEVDF + BORE ---
# EEVDF é o scheduler padrão desde Linux 6.6, completado no 6.12
CONFIG_PREEMPT=y
CONFIG_PREEMPT_VOLUNTARY=n
CONFIG_PREEMPT_NONE=n
# BORE (Burst-Oriented Response Enhancer) — patch KanelOS
CONFIG_SCHED_BORE=y
CONFIG_SCHED_BORE_DEFAULT_BURST_PENALTY=24
# sched_ext — BPF extensible scheduler (mergeado no 6.12)
CONFIG_SCHED_CLASS_EXT=y
# Timer frequency alta para desktop responsivo
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_NO_HZ_IDLE=y
CONFIG_NO_HZ_FULL=n
# SCHED_DEADLINE servers (anti-starvation)
CONFIG_SCHED_DEADLINE=y

# --- Preempção e Latência ---
CONFIG_PREEMPT_COUNT=y
CONFIG_PREEMPT_RCU=y
CONFIG_RCU_NOCB_CPU=y
CONFIG_RCU_BOOST=y
CONFIG_RCU_BOOST_DELAY=500

# --- Gerenciamento de Memória ---
# MGLRU — Multi-Generational LRU (mergeado no 6.1)
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y
CONFIG_LRU_GEN_STATS=y
# KSM — Kernel Samepage Merging
CONFIG_KSM=y
# Transparent Huge Pages
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
# Zswap com Zstd
CONFIG_ZSWAP=y
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_ZSTD=y
CONFIG_ZSWAP_ZPOOL_DEFAULT_ZSMALLOC=y
CONFIG_ZSMALLOC=y
# NUMA
CONFIG_NUMA=y
CONFIG_NUMA_BALANCING=y
CONFIG_NUMA_BALANCING_DEFAULT_ENABLED=y
# Memória grande
CONFIG_HIGHMEM64G=y
CONFIG_X86_PAE=n
# Compactação de memória
CONFIG_COMPACTION=y
CONFIG_MIGRATION=y
CONFIG_MEMORY_HOTPLUG=y
CONFIG_MEMORY_HOTREMOVE=y
# Huge pages
CONFIG_HUGETLBFS=y
CONFIG_HUGETLB_PAGE=y
CONFIG_ARCH_WANT_HUGE_PMD_SHARE=y

# --- I/O: io_uring + NVMe Otimizado ---
CONFIG_IO_URING=y
CONFIG_IORING_UNIFIED_WORKER=y
# Block layer
CONFIG_BLOCK=y
CONFIG_BLK_DEV_BSG=y
CONFIG_BLK_DEV_INTEGRITY=y
CONFIG_BLK_CGROUP_IOCOST=y
CONFIG_BLK_CGROUP_IOPRIO=y
# Multi-queue I/O
CONFIG_MQ_IOSCHED_DEADLINE=y
CONFIG_MQ_IOSCHED_KYBER=y
CONFIG_IOSCHED_BFQ=y
CONFIG_BFQ_GROUP_IOSCHED=y
# NVMe
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_MULTIPATH=y
CONFIG_NVME_HWMON=y
CONFIG_NVME_TCP=y
CONFIG_NVME_FABRICS=y
# SATA/AHCI
CONFIG_SATA_AHCI=y
CONFIG_SATA_MOBILE_LPM_POLICY=3
# USB Storage
CONFIG_USB_STORAGE=y
CONFIG_USB_UAS=y

# --- Sistema de Arquivos ---
# Ext4 (padrão, estável)
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
# Btrfs (snapshots, compressão Zstd)
CONFIG_BTRFS_FS=y
CONFIG_BTRFS_FS_POSIX_ACL=y
# XFS (alta performance, servidores)
CONFIG_XFS_FS=y
CONFIG_XFS_QUOTA=y
CONFIG_XFS_POSIX_ACL=y
# F2FS (SSDs, dispositivos flash)
CONFIG_F2FS_FS=y
CONFIG_F2FS_FS_COMPRESSION=y
CONFIG_F2FS_FS_ZSTD=y
# tmpfs, procfs, sysfs
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
# OverlayFS (containers)
CONFIG_OVERLAY_FS=y
# FUSE
CONFIG_FUSE_FS=y
CONFIG_CUSE=y
# exFAT, VFAT (compatibilidade)
CONFIG_EXFAT_FS=y
CONFIG_VFAT_FS=y
CONFIG_FAT_DEFAULT_UTF8=y
# NTFS3 (Windows, nativo no kernel 5.15+)
CONFIG_NTFS3_FS=y
CONFIG_NTFS3_LZX_XPRESS=y
# SquashFS (imagens comprimidas)
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_SQUASHFS_LZ4=y
CONFIG_SQUASHFS_XZ=y
# EROFS (Android, imagens somente leitura)
CONFIG_EROFS_FS=y
CONFIG_EROFS_FS_ZIP=y
CONFIG_EROFS_FS_ZIP_ZSTD=y
# Verificação de integridade
CONFIG_DM_VERITY=y
CONFIG_FS_VERITY=y
CONFIG_FS_VERITY_BUILTIN_SIGNATURES=y

# --- CPU Frequency Scaling ---
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_USERSPACE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_CONSERVATIVE=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
# Intel P-state (12th Gen+ com EPP)
CONFIG_X86_INTEL_PSTATE=y
# AMD P-state (Ryzen 5000+ com EPP — ativo por padrão)
CONFIG_X86_AMD_PSTATE=y
CONFIG_X86_AMD_PSTATE_DEFAULT_MODE=3

# --- CPU Idle ---
CONFIG_CPU_IDLE=y
CONFIG_CPU_IDLE_GOV_LADDER=y
CONFIG_CPU_IDLE_GOV_MENU=y
CONFIG_CPU_IDLE_GOV_TEO=y
CONFIG_INTEL_IDLE=y

# --- Energia e Gerenciamento de Energia ---
CONFIG_ACPI=y
CONFIG_ACPI_SLEEP=y
CONFIG_ACPI_PROCESSOR=y
CONFIG_ACPI_CPPC_LIB=y
CONFIG_ACPI_THERMAL=y
CONFIG_ACPI_FAN=y
CONFIG_ACPI_DOCK=y
CONFIG_ACPI_BATTERY=y
CONFIG_ACPI_AC=y
CONFIG_ACPI_BUTTON=y
CONFIG_ACPI_VIDEO=y
CONFIG_ACPI_HOTPLUG_CPU=y
# Intel RAPL (Running Average Power Limit)
CONFIG_INTEL_RAPL=y
CONFIG_INTEL_RAPL_CORE=y
# AMD PMC
CONFIG_AMD_PMC=y
# Suspend e Hibernate
CONFIG_SUSPEND=y
CONFIG_HIBERNATION=y
CONFIG_PM_SLEEP=y
CONFIG_PM_AUTOSLEEP=y
CONFIG_PM_WAKELOCKS=y
# Thermal
CONFIG_THERMAL=y
CONFIG_THERMAL_HWMON=y
CONFIG_CPU_THERMAL=y
CONFIG_INTEL_PCH_THERMAL=y
CONFIG_AMD_THERMAL=y

# --- Rede ---
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_TCP_CONG_ADVANCED=y
# BBR v3 (melhor congestion control para redes modernas)
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"
# Netfilter
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_TABLES=y
CONFIG_NFT_COUNTER=y
CONFIG_NFT_LOG=y
CONFIG_NFT_LIMIT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_NAT=y
# XDP/eBPF networking
CONFIG_XDP_SOCKETS=y
CONFIG_NET_SCH_DEFAULT=y
CONFIG_NET_SCH_FQ=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCH_CAKE=y
# WiFi
CONFIG_WIRELESS=y
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_IWLWIFI=y
CONFIG_IWLMVM=y
CONFIG_ATH11K=y
CONFIG_ATH12K=y
CONFIG_MT7921E=y
CONFIG_RTW89=y
# Bluetooth
CONFIG_BT=y
CONFIG_BT_RFCOMM=y
CONFIG_BT_BNEP=y
CONFIG_BT_HIDP=y
CONFIG_BT_LE=y
CONFIG_BT_LEDS=y
CONFIG_BT_MSFTEXT=y
CONFIG_BT_INTEL=y
CONFIG_BT_ATH3K=y
# Ethernet
CONFIG_NET_VENDOR_REALTEK=y
CONFIG_R8169=y
CONFIG_NET_VENDOR_INTEL=y
CONFIG_E1000E=y
CONFIG_IGB=y
CONFIG_IXGBE=y
CONFIG_I40E=y
CONFIG_ICE=y
CONFIG_NET_VENDOR_MELLANOX=y
CONFIG_MLX5_CORE=y
CONFIG_MLX5_CORE_EN=y

# --- GPU e Display ---
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_FBDEV_EMULATION=y
# AMD GPU (RDNA2/3 — driver open-source)
CONFIG_DRM_AMDGPU=y
CONFIG_DRM_AMDGPU_SI=y
CONFIG_DRM_AMDGPU_CIK=y
CONFIG_DRM_AMD_DC=y
CONFIG_DRM_AMD_DC_DCN=y
CONFIG_DRM_AMD_DC_FP=y
# Intel GPU (Arc Xe, i915)
CONFIG_DRM_I915=y
CONFIG_DRM_I915_GVT=y
CONFIG_DRM_XE=y
# NVIDIA (Nouveau open-source + GSP firmware)
CONFIG_DRM_NOUVEAU=y
CONFIG_DRM_NOUVEAU_GSP_DEFAULT=y
# Display
CONFIG_DRM_DP_AUX_CHARDEV=y
CONFIG_DRM_DISPLAY_CONNECTOR=y
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_GENERIC=y
# Framebuffer
CONFIG_FB=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_LOGO=y

# --- Áudio ---
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_HDA=y
CONFIG_SND_HDA_INTEL=y
CONFIG_SND_HDA_CODEC_REALTEK=y
CONFIG_SND_HDA_CODEC_ANALOG=y
CONFIG_SND_HDA_CODEC_SIGMATEL=y
CONFIG_SND_HDA_CODEC_VIA=y
CONFIG_SND_HDA_CODEC_HDMI=y
CONFIG_SND_HDA_CODEC_CIRRUS=y
CONFIG_SND_HDA_CODEC_CONEXANT=y
CONFIG_SND_HDA_CODEC_CA0110=y
CONFIG_SND_HDA_CODEC_CA0132=y
CONFIG_SND_HDA_CODEC_CMEDIA=y
CONFIG_SND_HDA_CODEC_SI3054=y
CONFIG_SND_HDA_GENERIC=y
# USB Audio
CONFIG_SND_USB_AUDIO=y
CONFIG_SND_USB_UA101=y
# Sound Open Firmware (laptops modernos)
CONFIG_SND_SOC=y
CONFIG_SND_SOF=y
CONFIG_SND_SOF_INTEL_TOPLEVEL=y
CONFIG_SND_SOF_AMD_TOPLEVEL=y
# PipeWire/ALSA
CONFIG_SND_SEQUENCER=y
CONFIG_SND_MIXER_OSS=y
CONFIG_SND_PCM_OSS=y

# --- USB ---
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_UHCI_HCD=y
CONFIG_USB4=y
CONFIG_THUNDERBOLT=y
CONFIG_USB_TYPEC=y
CONFIG_USB_TYPEC_UCSI=y
CONFIG_USB_PD_VDOS=y
# USB Power Delivery
CONFIG_USB_POWER_DELIVERY=y

# --- Input ---
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_INPUT_JOYSTICK=y
CONFIG_INPUT_TABLET=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_HID_MULTITOUCH=y
CONFIG_HID_LOGITECH=y
CONFIG_HID_RAZER=y
CONFIG_HID_CORSAIR=y
CONFIG_HID_STEELSERIES=y
# Touchpad
CONFIG_MOUSE_PS2=y
CONFIG_MOUSE_PS2_SYNAPTICS=y
CONFIG_MOUSE_PS2_ELANTECH=y

# --- Virtualização ---
CONFIG_KVM=y
CONFIG_KVM_INTEL=y
CONFIG_KVM_AMD=y
CONFIG_KVM_AMD_SEV=y
CONFIG_VHOST_NET=y
CONFIG_VHOST_VSOCK=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y

# --- Containers ---
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_TIME_NS=y
CONFIG_MNT_NS=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_NET_CLASSID=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_BPF=y
CONFIG_CGROUP_RDMA=y
CONFIG_CGROUP_MISC=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_BLKIO_CGROUP=y
CONFIG_CPUSETS=y

# --- Segurança ---
# KASLR
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y
# Stack protection
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y
# KPTI
CONFIG_PAGE_TABLE_ISOLATION=y
# CFI (requer Clang)
# CONFIG_CFI_CLANG=y
# Shadow Stack (Intel CET)
CONFIG_X86_USER_SHADOW_STACK=y
# Seccomp
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
# Linux Security Modules
CONFIG_SECURITY=y
CONFIG_SECURITY_NETWORK=y
CONFIG_SECURITY_PATH=y
CONFIG_LSM="lockdown,yama,integrity,apparmor,bpf"
CONFIG_SECURITY_APPARMOR=y
CONFIG_SECURITY_APPARMOR_BOOTPARAM_VALUE=1
CONFIG_SECURITY_YAMA=y
CONFIG_INTEGRITY=y
CONFIG_IMA=y
CONFIG_IMA_DEFAULT_HASH_SHA256=y
CONFIG_EVM=y
# IPE (Integrity Policy Enforcement — novo no 6.12)
CONFIG_SECURITY_IPE=y
CONFIG_IPE_PROP_DM_VERITY=y
CONFIG_IPE_PROP_FS_VERITY=y
# Lockdown
CONFIG_SECURITY_LOCKDOWN_LSM=y
# BPF LSM
CONFIG_BPF_LSM=y
# Hardening
CONFIG_HARDENED_USERCOPY=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_SHUFFLE_PAGE_ALLOCATOR=y
# Mitigações de CPU (balanceado: segurança + performance)
CONFIG_CPU_MITIGATIONS=y
CONFIG_RETPOLINE=y
CONFIG_SPECULATION_MITIGATIONS=y

# --- eBPF ---
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_UNPRIV_DEFAULT_OFF=y
CONFIG_BPF_EVENTS=y
CONFIG_FTRACE_SYSCALLS=y
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_UPROBE_EVENTS=y
CONFIG_TRACING=y
CONFIG_DYNAMIC_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_PERF_EVENTS=y
CONFIG_PERF_EVENTS_INTEL_UNCORE=y
CONFIG_PERF_EVENTS_AMD_POWER=y

# --- Rust no Kernel ---
CONFIG_RUST=y
CONFIG_RUST_IS_AVAILABLE=y

# --- Módulos ---
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_UNLOAD=y
CONFIG_MODVERSIONS=y
CONFIG_MODULE_SRCVERSION_ALL=y
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_SHA512=y

# --- Debugging (desabilitado em produção) ---
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_INFO=n
CONFIG_KASAN=n
CONFIG_UBSAN=n
# Manter símbolos mínimos para crash dumps
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=n

# --- Compressão do Kernel ---
CONFIG_KERNEL_ZSTD=y

# --- Misc ---
CONFIG_EXPERT=y
CONFIG_MULTIUSER=y
CONFIG_SYSFS_SYSCALL=y
CONFIG_POSIX_TIMERS=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_FUTEX=y
CONFIG_FUTEX2=y
CONFIG_AIO=y
CONFIG_ADVISE_SYSCALLS=y
CONFIG_MEMBARRIER=y
CONFIG_CHECKPOINT_RESTORE=y
CONFIG_SHMEM=y
CONFIG_TMPFS=y
CONFIG_MMAP_ALLOW_UNINITIALIZED=n
