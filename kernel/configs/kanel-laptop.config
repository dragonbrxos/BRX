# =============================================================================
# KanelOS — Configuração de Kernel: Perfil Laptop
# Base: Linux 6.12 LTS
# Otimizado para: Economia de Energia, Mobilidade, Bateria
# =============================================================================

CONFIG_LOCALVERSION="-kanelos-laptop"
CONFIG_LOCALVERSION_AUTO=y

# --- Scheduler Balanceado ---
CONFIG_PREEMPT=y
CONFIG_SCHED_BORE=y
CONFIG_SCHED_CLASS_EXT=y
CONFIG_HZ_250=y
CONFIG_HZ=250
CONFIG_NO_HZ_IDLE=y

# --- CPU Frequency: Economia de Energia ---
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
# Intel P-state com EPP (Energy Performance Preference)
CONFIG_X86_INTEL_PSTATE=y
# AMD P-state com EPP (Ryzen 5000+, modo ativo)
CONFIG_X86_AMD_PSTATE=y
CONFIG_X86_AMD_PSTATE_DEFAULT_MODE=3
# CPU Idle profundo
CONFIG_CPU_IDLE=y
CONFIG_CPU_IDLE_GOV_TEO=y
CONFIG_INTEL_IDLE=y

# --- ACPI e Energia ---
CONFIG_ACPI=y
CONFIG_ACPI_SLEEP=y
CONFIG_ACPI_PROCESSOR=y
CONFIG_ACPI_BATTERY=y
CONFIG_ACPI_AC=y
CONFIG_ACPI_BUTTON=y
CONFIG_ACPI_VIDEO=y
CONFIG_ACPI_FAN=y
CONFIG_ACPI_THERMAL=y
CONFIG_INTEL_RAPL=y
CONFIG_AMD_PMC=y
CONFIG_SUSPEND=y
CONFIG_HIBERNATION=y
CONFIG_PM_SLEEP=y
CONFIG_PM_AUTOSLEEP=y
CONFIG_PM_WAKELOCKS=y
# Runtime PM
CONFIG_PM_RUNTIME=y
CONFIG_PM_DEVFREQ=y
# Backlight
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_GENERIC=y
CONFIG_BACKLIGHT_APPLE=y

# --- Memória Eficiente ---
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y
CONFIG_KSM=y
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_ZSWAP=y
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_ZSTD=y

# --- WiFi e Bluetooth (essenciais para laptop) ---
CONFIG_WIRELESS=y
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_MAC80211_RC_MINSTREL=y
CONFIG_IWLWIFI=y
CONFIG_IWLMVM=y
CONFIG_ATH11K=y
CONFIG_ATH12K=y
CONFIG_MT7921E=y
CONFIG_RTW89=y
CONFIG_BT=y
CONFIG_BT_INTEL=y
CONFIG_BT_LE=y

# --- Display e GPU ---
CONFIG_DRM=y
CONFIG_DRM_AMDGPU=y
CONFIG_DRM_AMD_DC=y
CONFIG_DRM_I915=y
CONFIG_DRM_XE=y
CONFIG_DRM_NOUVEAU=y
# Hybrid graphics (PRIME)
CONFIG_DRM_PRIME=y
CONFIG_VGA_SWITCHEROO=y
# Panel self refresh
CONFIG_DRM_I915_SELFTEST=n

# --- Touchpad e Input ---
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_MOUSE_PS2=y
CONFIG_MOUSE_PS2_SYNAPTICS=y
CONFIG_MOUSE_PS2_ELANTECH=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_HID_MULTITOUCH=y
CONFIG_TABLET_USB_WACOM=y

# --- Câmera (laptops modernos) ---
CONFIG_MEDIA_SUPPORT=y
CONFIG_VIDEO_DEV=y
CONFIG_VIDEO_V4L2=y
CONFIG_USB_VIDEO_CLASS=y
CONFIG_MEDIA_USB_SUPPORT=y
CONFIG_VIDEO_IPU3_IMGU=y
CONFIG_VIDEO_IPU3_CIO2=y

# --- Fingerprint e Biometria ---
CONFIG_HID_SENSOR_HUB=y
CONFIG_HID_SENSOR_ACCEL_3D=y
CONFIG_HID_SENSOR_GYRO_3D=y

# --- Thunderbolt / USB4 ---
CONFIG_THUNDERBOLT=y
CONFIG_USB4=y
CONFIG_USB_TYPEC=y
CONFIG_USB_TYPEC_UCSI=y
CONFIG_USB_POWER_DELIVERY=y

# --- Segurança ---
CONFIG_RANDOMIZE_BASE=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_SECCOMP=y
CONFIG_SECURITY=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_FORTIFY_SOURCE=y

# --- eBPF ---
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_KPROBES=y
CONFIG_PERF_EVENTS=y

# --- Módulos e Compressão ---
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_RUST=y
CONFIG_KERNEL_ZSTD=y
