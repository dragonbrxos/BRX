# =============================================================================
# KanelOS — Configuração de Kernel: Perfil Real-Time
# Base: Linux 6.12 LTS (PREEMPT_RT mergeado no mainline!)
# Otimizado para: Áudio Profissional, Automação Industrial, Robótica
# =============================================================================
# NOTA: PREEMPT_RT foi finalmente mergeado no mainline Linux 6.12 após
# 20 anos de desenvolvimento. Esta configuração o habilita.
# =============================================================================

CONFIG_LOCALVERSION="-kanelos-rt"
CONFIG_LOCALVERSION_AUTO=y

# --- PREEMPT_RT — O diferencial do Linux 6.12 ---
CONFIG_PREEMPT_RT=y
CONFIG_PREEMPT=n
CONFIG_PREEMPT_VOLUNTARY=n
CONFIG_PREEMPT_NONE=n

# --- Timer de Alta Resolução ---
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_HIGH_RES_TIMERS=y
CONFIG_NO_HZ_FULL=y
CONFIG_RCU_NOCB_CPU=y
CONFIG_RCU_BOOST=y
CONFIG_RCU_BOOST_DELAY=0

# --- Scheduler Real-Time ---
CONFIG_SCHED_CLASS_EXT=y
# scx_lavd é ideal para RT (Latency-Aware Virtual Deadline)
CONFIG_RT_GROUP_SCHED=y
CONFIG_SCHED_DEADLINE=y

# --- CPU Isolation para RT ---
CONFIG_CPU_ISOLATION=y
CONFIG_CPUSETS=y
CONFIG_NO_HZ_FULL_ALL=n

# --- Memória RT ---
CONFIG_LRU_GEN=y
CONFIG_TRANSPARENT_HUGEPAGE=n
CONFIG_ZSWAP=n
CONFIG_NUMA_BALANCING=n

# --- I/O RT ---
CONFIG_IO_URING=y
CONFIG_BLK_DEV_NVME=y
CONFIG_IOSCHED_NOOP=y
CONFIG_MQ_IOSCHED_DEADLINE=y

# --- Rede RT ---
CONFIG_NET=y
CONFIG_INET=y
CONFIG_TCP_CONG_BBR=y

# --- Áudio RT ---
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_HDA=y
CONFIG_SND_HDA_INTEL=y
CONFIG_SND_USB_AUDIO=y
CONFIG_SND_SOC=y
CONFIG_SND_SOF=y
# ALSA com prioridade RT
CONFIG_SND_HRTIMER=y
CONFIG_SND_RAWMIDI=y
CONFIG_SND_SEQUENCER=y

# --- CPU Frequency RT (performance fixa) ---
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
CONFIG_X86_INTEL_PSTATE=y
CONFIG_X86_AMD_PSTATE=y

# --- Segurança ---
CONFIG_RANDOMIZE_BASE=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_SECCOMP=y
CONFIG_SECURITY=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_HARDENED_USERCOPY=y

# --- eBPF ---
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_KPROBES=y
CONFIG_PERF_EVENTS=y

# --- Módulos ---
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_RUST=y
CONFIG_KERNEL_ZSTD=y
