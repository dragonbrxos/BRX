# =============================================================================
# KanelOS — Configuração de Kernel: Perfil Servidor
# Base: Linux 6.12 LTS
# Otimizado para: Servidores Web, Banco de Dados, Containers, Cloud
# =============================================================================

CONFIG_LOCALVERSION="-kanelos-server"
CONFIG_LOCALVERSION_AUTO=y

# --- Scheduler: EEVDF sem BORE (throughput > responsividade) ---
CONFIG_PREEMPT_NONE=y
CONFIG_PREEMPT=n
CONFIG_PREEMPT_VOLUNTARY=n
CONFIG_SCHED_CLASS_EXT=y
CONFIG_HZ_250=y
CONFIG_HZ=250
CONFIG_NO_HZ_IDLE=y
CONFIG_NO_HZ_FULL=y
CONFIG_RCU_NOCB_CPU=y

# --- CPU ---
CONFIG_NR_CPUS=4096
CONFIG_SCHED_SMT=y
CONFIG_SCHED_MC=y
CONFIG_NUMA=y
CONFIG_NUMA_BALANCING=y

# --- Memória ---
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y
CONFIG_KSM=y
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=y
CONFIG_ZSWAP=y
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_ZSTD=y
CONFIG_MEMORY_HOTPLUG=y
CONFIG_MEMORY_HOTREMOVE=y
CONFIG_BALLOON_COMPACTION=y

# --- I/O Otimizado para Servidor ---
CONFIG_IO_URING=y
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_MULTIPATH=y
CONFIG_NVME_TCP=y
CONFIG_NVME_RDMA=y
CONFIG_NVME_FC=y
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_BLK_DEV_SR=y
CONFIG_RAID6_PQ=y
CONFIG_MD=y
CONFIG_BLK_DEV_MD=y
CONFIG_MD_RAID0=y
CONFIG_MD_RAID1=y
CONFIG_MD_RAID10=y
CONFIG_MD_RAID456=y
CONFIG_DM_THIN_PROVISIONING=y
CONFIG_DM_CACHE=y
CONFIG_DM_WRITECACHE=y
CONFIG_DM_VERITY=y
CONFIG_DM_INTEGRITY=y

# --- Rede de Alta Performance ---
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_NET_SCH_FQ=y
CONFIG_NET_SCH_CAKE=y
CONFIG_XDP_SOCKETS=y
# RDMA / InfiniBand
CONFIG_INFINIBAND=y
CONFIG_INFINIBAND_RDMAVT=y
CONFIG_INFINIBAND_IPOIB=y
CONFIG_INFINIBAND_ISER=y
CONFIG_INFINIBAND_ISERT=y
CONFIG_RDMA_RXE=y
# SR-IOV
CONFIG_PCI_IOV=y
CONFIG_PCI_PRI=y
CONFIG_PCI_PASID=y
# Mellanox (data centers)
CONFIG_MLX5_CORE=y
CONFIG_MLX5_CORE_EN=y
CONFIG_MLX5_CORE_EN_DCB=y
CONFIG_MLX5_INFINIBAND=y
CONFIG_MLX4_CORE=y
CONFIG_MLX4_EN=y
# Intel 10/25/100GbE
CONFIG_IXGBE=y
CONFIG_I40E=y
CONFIG_ICE=y
CONFIG_IAVF=y

# --- Sistema de Arquivos para Servidor ---
CONFIG_EXT4_FS=y
CONFIG_XFS_FS=y
CONFIG_XFS_QUOTA=y
CONFIG_BTRFS_FS=y
CONFIG_OVERLAY_FS=y
CONFIG_NFS_FS=y
CONFIG_NFS_V4=y
CONFIG_NFS_V4_1=y
CONFIG_NFS_V4_2=y
CONFIG_NFSD=y
CONFIG_NFSD_V4=y
CONFIG_CIFS=y
CONFIG_SMB_SERVER=y
CONFIG_CEPH_FS=y
CONFIG_CEPH_LIB=y
CONFIG_GFS2_FS=y
CONFIG_OCFS2_FS=y

# --- Containers e Virtualização ---
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_TIME_NS=y
CONFIG_MNT_NS=y
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_BPF=y
CONFIG_CPUSETS=y
CONFIG_KVM=y
CONFIG_KVM_INTEL=y
CONFIG_KVM_AMD=y
CONFIG_KVM_AMD_SEV=y
CONFIG_VHOST_NET=y
CONFIG_VHOST_VSOCK=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VFIO=y
CONFIG_VFIO_PCI=y
CONFIG_IOMMU_SUPPORT=y
CONFIG_INTEL_IOMMU=y
CONFIG_AMD_IOMMU=y
CONFIG_IOMMU_DEFAULT_DMA_STRICT=y

# --- Segurança Servidor ---
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_PAGE_TABLE_ISOLATION=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_SECURITY=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_SECURITY_YAMA=y
CONFIG_BPF_LSM=y
CONFIG_SECURITY_IPE=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y

# --- eBPF para Observabilidade ---
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_UPROBE_EVENTS=y
CONFIG_TRACING=y
CONFIG_PERF_EVENTS=y

# --- CPU Frequency ---
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
CONFIG_X86_INTEL_PSTATE=y
CONFIG_X86_AMD_PSTATE=y
CONFIG_X86_AMD_PSTATE_DEFAULT_MODE=2

# --- Compressão ---
CONFIG_KERNEL_ZSTD=y
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_RUST=y
